{
  "name": "tamarind",
  "productName": "Tamarind",
  "version": "1.0.0",
  "upgrade": "pear://e8nmgdoqu9wyadei7c15itpze7goqfo5q3hd5ujf7yhtwuoy8fzo",
  "description": "Tamarind - local-first P2P collaborative whiteboard (Electron + Pear)",
  "license": "Apache-2.0",
  "author": "dev.tamarind",
  "type": "commonjs",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "lint": "prettier --check . && lunte",
    "format": "prettier --write . && lunte --fix",
    "dev:vite": "vite",
    "dev:vite:guest": "vite --port 5174",
    "dev:electron": "wait-on tcp:5173 && cross-env PEAR_DEV_SERVER_URL=http://localhost:5173 electron-forge start -- --no-updates",
    "dev:electron:guest": "wait-on tcp:5174 && cross-env PEAR_DEV_SERVER_URL=http://localhost:5174 electron-forge start -- --no-updates --storage ./tmp-tamarind-guest",
    "build:worker-specs": "node schema.js",
    "start": "npm run build:worker-specs && concurrently -k -n vite,electron -c blue,green \"npm:dev:vite\" \"npm:dev:electron\"",
    "start:guest": "npm run build:worker-specs && concurrently -k -n vite,electron -c blue,green \"npm:dev:vite:guest\" \"npm:dev:electron:guest\"",
    "build:renderer": "npm run build:worker-specs && vite build",
    "package": "npm run build:renderer && electron-forge package",
    "make": "npm run build:renderer && electron-forge make"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "autobase": "^7.28.1",
    "b4a": "^1.8.1",
    "bare-fs": "^4.7.1",
    "bare-path": "^3.0.0",
    "blind-pairing": "^2.3.1",
    "corestore": "^7.9.1",
    "debounceify": "^1.1.0",
    "framed-stream": "^1.0.1",
    "framer-motion": "^12.0.0",
    "graceful-goodbye": "^1.3.3",
    "hyperdb": "^6.7.0",
    "hyperdispatch": "^1.6.0",
    "hyperschema": "^1.21.0",
    "hyperswarm": "^4.17.0",
    "lucide-react": "^0.475.0",
    "paparam": "^1.10.0",
    "pear-runtime": "^1.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ready-resource": "^1.2.0",
    "which-runtime": "^1.3.2",
    "z32": "^1.1.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-msix": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "app-builder-lib": "^26.8.1",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^40.2.1",
    "electron-forge-plugin-prune-prebuilds": "^1.0.0",
    "electron-forge-plugin-universal-prebuilds": "^1.0.0",
    "lunte": "^1.6.0",
    "pear-electron-forge-maker-appimage": "^2.0.0",
    "pear-electron-forge-maker-flatpak": "^0.0.4",
    "pear-electron-forge-maker-snap": "^0.0.10",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.0"
  }
}
